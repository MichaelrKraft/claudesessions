{
  "description": "coder1-mem hooks — SessionStart briefing injection + Stop hook session capture",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/inject-context.sh",
            "async": false,
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/archive-session.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
