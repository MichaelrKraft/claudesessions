#!/bin/bash
#
# coder1-mem — Coder1 Memory CLI
#
# Thin wrapper that forwards to the `sessions` CLI in the same directory.
# Branded as `coder1-mem` for the Coder1 Memory product line.
#
# Resolves its own real path (handles symlinks from ~/.claudesessions/bin/)
# so it always finds the sibling `sessions` script.

set -e

VERSION="coder1-mem 1.0.0"

# Handle --version without forwarding
if [ "$1" = "--version" ] || [ "$1" = "-V" ]; then
    echo "$VERSION"
    exit 0
fi

# Resolve real path of this script (follow symlinks portably)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

SESSIONS_BIN="$SCRIPT_DIR/sessions"

if [ ! -x "$SESSIONS_BIN" ]; then
    echo "coder1-mem: cannot find sessions CLI at $SESSIONS_BIN" >&2
    exit 1
fi

exec "$SESSIONS_BIN" "$@"
